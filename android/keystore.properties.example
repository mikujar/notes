# 复制为 keystore.properties 并填真实值（keystore.properties 已在 .gitignore）
#
# 一、一键生成证书与本文件（推荐，需本机已装 JDK 或 Android Studio）：
#   bash android/generate-release-keystore.sh
#
# 或手动生成（在 android/ 目录下执行，按提示设密码并记住）：
#   keytool -genkeypair -v -keystore mikujar-release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias mikujar
#
# 二、备案用的 MD5 / 公钥（用你真实的 keystore 路径与别名）：
#   keytool -list -v -keystore mikujar-release.jks -alias mikujar
#   看 Certificate fingerprints 里的 MD5（去掉冒号共 32 位十六进制）
#
# 三、填好下面四行，把 mikujar-release.jks 放在与本文件同一目录（android/）

storePassword=你的仓库密码
keyPassword=你的密钥密码
keyAlias=mikujar
storeFile=mikujar-release.jks
