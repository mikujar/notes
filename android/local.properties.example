# 复制为 local.properties（已在 .gitignore，每人本机路径不同）
# 装了 Android Studio 时，Mac 上一般是：
#   sdk.dir=/Users/你的用户名/Library/Android/sdk
# Windows 示例：
#   sdk.dir=C\:\\Users\\你的用户名\\AppData\\Local\\Android\\Sdk
#
# 或在终端临时导出（与 sdk.dir 二选一即可）：
#   export ANDROID_HOME=$HOME/Library/Android/sdk

sdk.dir=/Users/请改成你的用户名/Library/Android/sdk
